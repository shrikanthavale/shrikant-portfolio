# Recipient address for contact form emails
CONTACT_TO_EMAIL=you@example.com

# Primary email provider: Hostinger SMTP (used if configured)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@yourdomain.com
SMTP_PASS=your_email_password
CONTACT_FROM_EMAIL=Portfolio Contact <your_email@yourdomain.com>

# Fallback email provider: Resend (used if SMTP is not configured)
RESEND_API_KEY=your_resend_api_key

# Cloudflare Turnstile anti-spam (optional — omit both keys to disable)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Deployment health check auth token (set the same value in Vercel + GitHub secrets)
DEPLOY_HEALTH_TOKEN=long_random_token_value
